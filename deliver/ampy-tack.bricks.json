{"content": [{"id": "amptck1", "name": "code", "parent": 0, "children": [], "settings": {"code": "<style>\n/* =========================================================================\n   Ampy tack-sida — production CSS  ·  FluentSnippets / Bricks\n   SELF-CONTAINED & SCOPED to .ampy-tack. All units in px (does NOT rely on\n   html{font-size:62.5%} or any external token file). Outfit is assumed to be\n   loaded site-wide on ampy.se; a system fallback is provided.\n   Paste this verbatim into a FluentSnippets CSS snippet.\n   ========================================================================= */\n\n.ampy-tack{\n  --at-ink:#0b1030;\n  --at-ink-soft:rgba(11,16,48,.62);\n  --at-teal:#00a991;\n  --at-teal-deep:#018271;\n  --at-gold:#f6b53d;\n  --at-ease:cubic-bezier(.16,.84,.44,1);\n  --at-ease-soft:cubic-bezier(.33,1,.68,1);\n\n  position:relative; z-index:0;\n  min-height:100vh; min-height:100dvh;\n  display:flex; flex-direction:column; align-items:center; justify-content:center;\n  gap:clamp(16px, 2vw, 20px);\n  padding:clamp(24px, 4vw, 48px) clamp(16px, 1.25vw + 12px, 28px);\n  overflow:hidden;\n  box-sizing:border-box;\n  font-family:\"Outfit\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif;\n  color:var(--at-ink);\n  background:\n    radial-gradient(115% 85% at 14% -12%, rgba(0,169,145,.12) 0%, rgba(0,169,145,0) 46%),\n    radial-gradient(105% 75% at 94% 6%,  rgba(182,242,255,.48) 0%, rgba(182,242,255,0) 44%),\n    radial-gradient(120% 95% at 90% 112%, rgba(160,251,201,.28) 0%, rgba(160,251,201,0) 48%),\n    radial-gradient(115% 90% at 8% 104%, rgba(0,169,145,.08) 0%, rgba(0,169,145,0) 46%),\n    #f5f9ff;\n  -webkit-font-smoothing:antialiased;\n  text-rendering:optimizeLegibility;\n}\n.ampy-tack *,.ampy-tack *::before,.ampy-tack *::after{ box-sizing:border-box; }\n\n/* decorative aurora corner art (inline SVG in the markup) */\n.ampy-tack__aurora{ position:absolute; z-index:0; pointer-events:none; user-select:none; opacity:.8; height:auto; }\n.ampy-tack__aurora--top{ top:0; right:0; width:clamp(200px, 30vw, 400px); }\n.ampy-tack__aurora--bottom{ bottom:0; left:0; width:clamp(150px, 22vw, 280px); }\n\n/* the contained glass card = the anchor */\n.ampy-tack__card{\n  position:relative; z-index:1; width:100%; max-width:520px;\n  display:flex; flex-direction:column; align-items:center; text-align:center;\n  gap:clamp(18px, 2.4vw, 24px);\n  background:rgba(255,255,255,.72);\n  border:1px solid rgba(255,255,255,.9);\n  border-radius:clamp(24px, 0.83vw + 21px, 32px);\n  box-shadow:0 30px 70px rgba(9,11,50,.12), inset 0 1px 0 rgba(255,255,255,.6);\n  -webkit-backdrop-filter:blur(16px) saturate(1.1);\n  backdrop-filter:blur(16px) saturate(1.1);\n  padding:clamp(32px, 4.5vw, 52px) clamp(28px, 4vw, 56px);\n}\n.ampy-tack__intro{ display:flex; flex-direction:column; align-items:center; gap:clamp(16px, 2.2vw, 22px); }\n\n/* living pale-mint check */\n.ampy-tack__check{ position:relative; width:clamp(88px, 11vw, 104px); height:clamp(88px, 11vw, 104px); display:grid; place-items:center; }\n.ampy-tack__check-svg{ position:relative; z-index:2; width:100%; height:100%; overflow:visible; }\n.ampy-tack__halo{\n  position:absolute; inset:6%; z-index:1; border-radius:50%;\n  background:radial-gradient(circle, rgba(85,255,154,.30) 0%, rgba(85,255,154,0) 72%);\n  animation:ampy-tack-halo 4s var(--at-ease-soft) infinite;\n}\n.ampy-tack__disc{ transform-origin:center; animation:ampy-tack-disc 640ms var(--at-ease) both; }\n.ampy-tack__tick{ stroke-dasharray:120; stroke-dashoffset:120; animation:ampy-tack-tick 560ms var(--at-ease) 300ms both; }\n@keyframes ampy-tack-disc{ 0%{ transform:scale(.62); opacity:0; } 62%{ transform:scale(1.05); } 100%{ transform:scale(1); opacity:1; } }\n@keyframes ampy-tack-tick{ to{ stroke-dashoffset:0; } }\n@keyframes ampy-tack-halo{ 0%{ transform:scale(.8); opacity:0; } 34%{ opacity:.8; } 100%{ transform:scale(1.4); opacity:0; } }\n\n/* hero */\n.ampy-tack__hero{ display:flex; flex-direction:column; gap:clamp(13px, 0.73vw + 10px, 20px); }\n.ampy-tack__title{\n  margin:0; font-size:clamp(28px, 1.25vw + 24px, 40px); line-height:1.14; font-weight:500;\n  letter-spacing:-.018em; color:var(--at-ink); white-space:nowrap;\n}\n.ampy-tack__sub{\n  margin:0; font-size:clamp(16px, 0.21vw + 15px, 18px); line-height:1.5; font-weight:400;\n  color:var(--at-ink-soft); white-space:nowrap;\n}\n\n/* proof — plain text (rating only) */\n.ampy-tack__proof{ display:flex; flex-direction:column; align-items:center; gap:5px; }\n.ampy-tack__rating{ margin:0; display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:3px 7px; }\n.ampy-tack__stars{ display:inline-flex; gap:3px; }\n.ampy-tack__stars svg{ width:16px; height:16px; fill:var(--at-gold); }\n.ampy-tack__ratingtext{ font-size:clamp(14px, 0.21vw + 13px, 16px); font-weight:400; color:var(--at-ink-soft); line-height:1; }\n.ampy-tack__ratingtext strong{ font-weight:600; color:var(--at-ink); }\n\n/* hairline divider */\n.ampy-tack__divider{ width:60px; height:1px; border:0; margin:0;\n  background:linear-gradient(90deg, transparent, rgba(0,169,145,.35), transparent); }\n\n/* proportionate primary CTA */\n.ampy-tack__cta-wrap{ display:flex; flex-direction:column; align-items:center; gap:10px; }\n.ampy-tack__cta{\n  display:inline-flex; align-items:center; gap:8px; text-decoration:none;\n  padding:14px 28px; border-radius:999px;\n  font-size:clamp(14px, 0.21vw + 13px, 16px); font-weight:600; color:#fff;\n  background:linear-gradient(135deg,#00b89c,#018271);\n  box-shadow:0 10px 24px rgba(0,169,145,.3);\n  transition:transform .2s var(--at-ease), box-shadow .2s var(--at-ease);\n}\n.ampy-tack__cta:hover{ transform:translateY(-2px); box-shadow:0 16px 30px rgba(0,169,145,.38); }\n.ampy-tack__cta svg{ width:14px; height:13px; fill:currentColor; transition:transform .2s var(--at-ease); }\n.ampy-tack__cta:hover svg{ transform:translateX(3px); }\n\n/* ghost back-to-home (part of the centred group) */\n.ampy-tack__ghost{\n  position:relative; z-index:1;\n  font-size:clamp(14px, 0.21vw + 13px, 16px); font-weight:500; color:var(--at-ink-soft);\n  text-decoration:none; padding:9px 16px; border-radius:999px;\n  transition:color .18s ease, background .18s ease;\n}\n.ampy-tack__ghost:hover{ color:var(--at-teal-deep); background:rgba(0,169,145,.08); }\n\n.ampy-tack a:focus-visible{ outline:3px solid var(--at-teal); outline-offset:3px; border-radius:12px; }\n\n/* mobile */\n@media (max-width:520px){\n  .ampy-tack__card{ padding:36px 24px; gap:20px; border-radius:clamp(16px, 0.42vw + 15px, 20px); }\n  .ampy-tack__title{ font-size:clamp(24px, 0.83vw + 21px, 32px); white-space:normal; text-wrap:balance; }\n  .ampy-tack__sub{ font-size:clamp(16px, 0.21vw + 15px, 18px); white-space:normal; text-wrap:balance; }\n  .ampy-tack__title br, .ampy-tack__sub br{ display:none; }\n}\n\n/* motion safety */\n@media (prefers-reduced-motion: reduce){\n  .ampy-tack__disc,.ampy-tack__tick,.ampy-tack__halo{ animation:none !important; }\n  .ampy-tack__tick{ stroke-dashoffset:0; }\n  .ampy-tack__halo{ opacity:.5; transform:scale(1.1); }\n  .ampy-tack__cta,.ampy-tack__cta svg,.ampy-tack__ghost{ transition:none; }\n}\n\n</style>\n\n<div class=\"ampy-tack\">\n  <svg class=\"ampy-tack__aurora ampy-tack__aurora--top\" xmlns=\"http://www.w3.org/2000/svg\" width=\"399\" height=\"308\" viewBox=\"0 0 399 308\" fill=\"none\" aria-hidden=\"true\"><path opacity=\"0.55\" d=\"M398.501 19.1624V307.416C377.203 307.609 355.83 302.624 342.317 293.968C312.351 274.723 324.249 243.073 290.832 225.49C271.296 215.211 241.478 212.776 213.863 212.505C186.248 212.274 157.751 213.588 131.605 208.757C82.3243 199.637 54.8562 166.596 75.5674 141.361C85.1886 129.652 102.742 120.339 116.035 109.712C129.329 99.0458 138.436 85.3657 128.668 73.6951C108.838 50.0062 34.0715 54.798 7.77845 32.9254C-4.04606 23.1097 -1.54896 10.2412 9.61455 0.0390625H391.001L398.501 19.1624Z\" fill=\"url(#at_p0t)\"></path><path opacity=\"0.6\" d=\"M398.499 0V241.34C355.859 222.68 321.444 193.856 302.503 160.131C293.654 144.379 284.851 125.261 262.485 120.588C244.078 116.765 225.536 124.967 208.24 130.948C190.9 136.928 167.201 139.967 155.151 129.052C133.764 109.64 178.361 77.2222 157.196 57.6797C143.857 45.3595 116.646 50.4248 97.2152 43.8562C76.1396 36.6993 69.2478 15.8497 77.9626 0H398.499Z\" fill=\"url(#at_p1t)\"></path><defs><radialGradient id=\"at_p0t\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"translate(322.819 40.5771) scale(663.35 349.037)\"><stop offset=\"0.5\" stop-color=\"#b6f2ff\"></stop><stop offset=\"1\" stop-color=\"#f5f9ff\"></stop></radialGradient><radialGradient id=\"at_p1t\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"translate(372.244 23.8562) scale(378.832 278.434)\"><stop stop-color=\"#5cc5b6\"></stop><stop offset=\"0.5\" stop-color=\"#00a991\"></stop><stop offset=\"0.87\" stop-color=\"#5cc5b6\"></stop></radialGradient></defs></svg>\n  <svg class=\"ampy-tack__aurora ampy-tack__aurora--bottom\" xmlns=\"http://www.w3.org/2000/svg\" width=\"270\" height=\"226\" viewBox=\"0 0 270 226\" fill=\"none\" aria-hidden=\"true\"><path opacity=\"0.55\" d=\"M1.26485e-06 210.532L1.96698e-05 0.00397235C14.4308 -0.137147 28.9113 3.50376 38.0674 9.82597C58.37 23.8816 50.3087 46.9971 72.95 59.8391C86.1865 67.3467 106.39 69.1248 125.1 69.3224C143.81 69.4917 163.117 68.5321 180.832 72.0602C214.222 78.7211 232.833 102.853 218.8 121.283C212.281 129.835 200.389 136.637 191.382 144.399C182.375 152.188 176.205 162.18 182.823 170.703C196.258 188.005 246.915 184.505 264.73 200.48C272.741 207.649 271.05 217.047 263.486 224.499L14.5 225L1.26485e-06 210.532Z\" fill=\"url(#at_p0b)\"></path><path opacity=\"0.6\" d=\"M3.05544e-05 225.579L3.06452e-05 50C28.9339 63.6081 52.2862 84.628 65.139 109.223C71.143 120.71 77.1168 134.652 92.2928 138.06C104.784 140.848 117.365 134.866 129.101 130.505C140.868 126.144 156.949 123.927 165.125 131.887C179.638 146.043 149.376 169.685 163.737 183.936C172.789 192.921 191.253 189.227 204.438 194.017C218.739 199.237 223.416 214.441 217.502 226L3.05544e-05 225.579Z\" fill=\"url(#at_p1b)\"></path><defs><radialGradient id=\"at_p0b\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"translate(51.2778 194.892) rotate(-180) scale(449.445 254.921)\"><stop offset=\"0.5\" stop-color=\"#a0fbc9\"></stop><stop offset=\"1\" stop-color=\"#f5f9ff\"></stop></radialGradient><radialGradient id=\"at_p1b\" cx=\"0\" cy=\"0\" r=\"1\" gradientUnits=\"userSpaceOnUse\" gradientTransform=\"translate(17.8152 208.603) rotate(-180) scale(257.059 203.052)\"><stop stop-color=\"#5cc5b6\"></stop><stop offset=\"0.5\" stop-color=\"#00a991\"></stop><stop offset=\"0.87\" stop-color=\"#5cc5b6\"></stop></radialGradient></defs></svg>\n\n  <div class=\"ampy-tack__card\">\n    <div class=\"ampy-tack__intro\">\n      <div class=\"ampy-tack__check\" aria-hidden=\"true\">\n        <span class=\"ampy-tack__halo\"></span>\n        <svg class=\"ampy-tack__check-svg\" width=\"112\" height=\"112\" viewBox=\"0 0 174 174\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect class=\"ampy-tack__disc\" x=\"12\" y=\"12\" width=\"150\" height=\"150\" rx=\"75\" fill=\"#55FF9A\" fill-opacity=\"0.2\" stroke=\"#ffffff\" stroke-opacity=\"0.18\" stroke-width=\"24\"></rect>\n          <path class=\"ampy-tack__tick\" d=\"M118.582 66.3379L76.862 108.207L57.8984 89.1754\" stroke=\"#00A991\" stroke-width=\"12\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n        </svg>\n      </div>\n      <header class=\"ampy-tack__hero\">\n        <h1 class=\"ampy-tack__title\">Din förfrågan har blivit <br>mottagen!</h1>\n        <p class=\"ampy-tack__sub\">En av våra rådgivare kommer att kontakta dig <br>inom kort.</p>\n      </header>\n      <div class=\"ampy-tack__proof\" aria-label=\"Omdöme\">\n        <p class=\"ampy-tack__rating\">\n          <span class=\"ampy-tack__stars\" role=\"img\" aria-label=\"5 av 5 i betyg på Google\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.166L12 18.896l-7.335 3.864 1.401-8.166L.132 9.21l8.2-1.192z\"></path></svg>\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.166L12 18.896l-7.335 3.864 1.401-8.166L.132 9.21l8.2-1.192z\"></path></svg>\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.166L12 18.896l-7.335 3.864 1.401-8.166L.132 9.21l8.2-1.192z\"></path></svg>\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.166L12 18.896l-7.335 3.864 1.401-8.166L.132 9.21l8.2-1.192z\"></path></svg>\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 .587l3.668 7.431 8.2 1.192-5.934 5.784 1.401 8.166L12 18.896l-7.335 3.864 1.401-8.166L.132 9.21l8.2-1.192z\"></path></svg>\n          </span>\n          <span class=\"ampy-tack__ratingtext\"><strong>5 av 5</strong> · Betyg på Google</span>\n        </p>\n      </div>\n    </div>\n\n    <hr class=\"ampy-tack__divider\">\n\n    <div class=\"ampy-tack__cta-wrap\">\n      <a class=\"ampy-tack__cta\" href=\"https://ampy.se/elservice\">Utforska våra eltjänster\n        <svg viewBox=\"0 0 17 15\" aria-hidden=\"true\"><path d=\"M16.7071 8.07112C17.0976 7.68059 17.0976 7.04743 16.7071 6.65691L10.3431 0.292945C9.95262 -0.0975793 9.31946 -0.0975792 8.92893 0.292945C8.53841 0.683469 8.53841 1.31663 8.92893 1.70716L14.5858 7.36401L8.92893 13.0209C8.53841 13.4114 8.53841 14.0446 8.92893 14.4351C9.31946 14.8256 9.95262 14.8256 10.3431 14.4351L16.7071 8.07112ZM0 7.36401L8.74228e-08 8.36401L16 8.36401L16 7.36401L16 6.36401L-8.74228e-08 6.36401L0 7.36401Z\"></path></svg>\n      </a>\n    </div>\n  </div>\n\n  <a class=\"ampy-tack__ghost\" href=\"https://ampy.se/\">Till startsidan</a>\n</div>\n\n<script>\n/* =========================================================================\n   Ampy tack-sida — production JS  ·  FluentSnippets / Bricks\n   OPTIONAL enhancement only. The check + halo animations are pure CSS and\n   run on load without JS. This IIFE simply REPLAYS the check draw-in when\n   the block scrolls into view (useful if the block sits lower on a page).\n   Scoped to .ampy-tack, no dependencies, respects reduced-motion.\n   Paste verbatim into a FluentSnippets JS snippet (load in footer).\n   ========================================================================= */\n(function () {\n  var roots = document.querySelectorAll('.ampy-tack');\n  if (!roots.length) return;\n  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;\n  if (!('IntersectionObserver' in window)) return;\n\n  var io = new IntersectionObserver(function (entries) {\n    entries.forEach(function (entry) {\n      if (!entry.isIntersecting) return;\n      var svg = entry.target.querySelector('.ampy-tack__check-svg');\n      if (svg) {\n        // clone-and-replace resets the CSS animations so the tick draws in again\n        var clone = svg.cloneNode(true);\n        svg.parentNode.replaceChild(clone, svg);\n      }\n      io.unobserve(entry.target);\n    });\n  }, { threshold: 0.35 });\n\n  roots.forEach(function (r) { io.observe(r); });\n})();\n\n</script>\n", "executeCode": true}}], "source": "bricksCopiedElements", "sourceUrl": "https://ampy.se", "version": "2.3.9"}